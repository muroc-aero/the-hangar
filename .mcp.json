{
  "mcpServers": {
    "OpenAeroStruct": {
      "command": "uv",
      "args": ["run", "--directory", ".", "python", "-m", "hangar.oas.server"],
      "env": {
        "HANGAR_DATA_DIR": "./hangar_data"
      }
    },
    "OpenConcept": {
      "command": "uv",
      "args": ["run", "--directory", ".", "python", "-m", "hangar.ocp.server"],
      "env": {
        "HANGAR_DATA_DIR": "./hangar_data"
      }
    },
    "pyCycle": {
      "command": "uv",
      "args": ["run", "--directory", ".", "python", "-m", "hangar.pyc.server"],
      "env": {
        "HANGAR_DATA_DIR": "./hangar_data"
      }
    }
  }
}
