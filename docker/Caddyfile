# Caddyfile for reverse-proxying Hangar services.
#
# Each tool gets two routes:
#   1. handle_path /<tool>/*  — strips prefix, proxies MCP requests
#   2. handle /.well-known/oauth-protected-resource/<tool>  — RFC 9728
#      metadata discovery (path NOT stripped, FastMCP serves it as-is)
#
# For local development, access services directly on their exposed ports
# (e.g. http://localhost:8000 for OAS).

{$HANGAR_DOMAIN:localhost} {
	# --- OAS ---
	handle /.well-known/oauth-protected-resource/oas {
		reverse_proxy oas:8000
	}
	handle_path /oas/* {
		reverse_proxy oas:8000
	}

	# --- Future tools ---
	# handle /.well-known/oauth-protected-resource/ocp {
	# 	reverse_proxy ocp:8000
	# }
	# handle_path /ocp/* {
	# 	reverse_proxy ocp:8000
	# }

	handle {
		respond "Not Found" 404
	}
}
