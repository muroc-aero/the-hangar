# Production Caddyfile for Hangar multi-tool deployment.
#
# Each tool gets a path prefix on mcp.lakesideai.dev.
# handle_path strips the prefix before proxying, so each tool server
# sees requests at its own root (e.g. /mcp, /.well-known/*).
#
# Client connection URLs:
#   Claude Code:  claude mcp add --transport http oas https://mcp.lakesideai.dev/oas/mcp
#   claude.ai:    https://mcp.lakesideai.dev/oas/mcp
#   Codex:        codex mcp add oas --url https://mcp.lakesideai.dev/oas/mcp

auth.lakesideai.dev {
    @admin path /admin/* /realms/master/*
    handle @admin {
        respond "Forbidden" 403
    }

    reverse_proxy keycloak:8080
}

mcp.lakesideai.dev {
    header {
        X-Content-Type-Options "nosniff"
        X-Frame-Options "DENY"
        Strict-Transport-Security "max-age=31536000; includeSubDomains"
        -Server
    }

    # OAS MCP server
    handle_path /oas/* {
        reverse_proxy oas-mcp:8000
    }

    # OCP MCP server (uncomment when ready)
    # handle_path /ocp/* {
    #     reverse_proxy ocp-mcp:8000
    # }

    handle {
        respond "Not Found" 404
    }
}
