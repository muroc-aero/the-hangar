# Production Caddyfile for Hangar multi-tool deployment.
#
# Each tool gets two routes on mcp.lakesideai.dev:
#   1. handle_path /<tool>/*  — strips prefix, proxies MCP requests
#   2. handle /.well-known/oauth-protected-resource/<tool>  — RFC 9728
#      metadata discovery (path NOT stripped, FastMCP serves it as-is)
#
# Client connection URLs:
#   Claude Code:  claude mcp add --transport http oas https://mcp.lakesideai.dev/oas/mcp
#   claude.ai:    https://mcp.lakesideai.dev/oas/mcp
#   Codex:        codex mcp add oas --url https://mcp.lakesideai.dev/oas/mcp

auth.lakesideai.dev {
    @admin path /admin/* /realms/master/*
    handle @admin {
        respond "Forbidden" 403
    }

    reverse_proxy keycloak:8080
}

mcp.lakesideai.dev {
    header {
        X-Content-Type-Options "nosniff"
        X-Frame-Options "DENY"
        Strict-Transport-Security "max-age=31536000; includeSubDomains"
        -Server
    }

    # --- OAS ---
    # RFC 9728 OAuth protected resource metadata (no prefix stripping)
    handle /.well-known/oauth-protected-resource/oas {
        reverse_proxy oas-mcp:8000
    }
    # MCP + viewer requests (prefix stripped)
    handle_path /oas/* {
        reverse_proxy oas-mcp:8000
    }

    # --- OCP (uncomment when ready) ---
    # handle /.well-known/oauth-protected-resource/ocp {
    #     reverse_proxy ocp-mcp:8000
    # }
    # handle_path /ocp/* {
    #     reverse_proxy ocp-mcp:8000
    # }

    handle {
        respond "Not Found" 404
    }
}
