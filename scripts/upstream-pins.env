# Single source of truth for upstream repo pins.
#
# Consumed by:
#   - scripts/setup-upstream.sh (sources this file, checks out each ref)
#   - .github/workflows/ci.yml (sources this file before cloning upstreams)
#   - packages/{oas,ocp,pyc}/Dockerfile ARG defaults (kept in sync by hand;
#     update them when bumping a pin here)
#
# Use full commit SHAs so builds are reproducible. To bump: update the SHA,
# run scripts/setup-upstream.sh, run the test suite, then update the
# matching Dockerfile ARG default.

# OpenAeroStruct (tag v2.12.0)
OAS_REF=0a4d614f9494cbadaba4a6fa32a33d6e54e14f34

# OpenConcept (v1.2.6 + 10 commits)
OCP_REF=0d2adeb6f6855b3cbe77b1c1453c5cf22c7fe5ca

# pyCycle (4.4.0 + 2 commits; scripts/pycycle-numpy2.patch applies on top,
# tracking OpenMDAO/pyCycle#116)
PYC_REF=d1dda5ffe200c88336a64ffd13b6c59b5f63343b

# Reference-only clones (not required by uv sync; skipped with --required)
# OpenMDAO (3.43.0 + 31 commits)
OM_REF=8221320ffbcfe1f9d717797bc00a1d0e936154f4
# AeroSandbox
ASB_REF=790ac4f2ed6754e61046fe8cfa5ebb2004ab0c61
